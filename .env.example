# ============================================================
# RentInAlvin Website Configuration
# Copy this file to .env and fill in real values
# ============================================================

# Server
PORT=3000
NODE_ENV=development
SITE_URL=http://localhost:3000

# ----------------------------------------------------------
# Email Provider — choose ONE and configure it
# ----------------------------------------------------------
# Options: smtp, resend, sendgrid
EMAIL_PROVIDER=smtp

# Sender configuration
EMAIL_FROM=no-reply@rentinalvin.com
EMAIL_FROM_NAME=RentInAlvin Website
EMAIL_REPLY_TO=office@yellowstone-am.com

# SMTP settings (if EMAIL_PROVIDER=smtp)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Resend settings (if EMAIL_PROVIDER=resend)
RESEND_API_KEY=re_xxxxxxxx

# SendGrid settings (if EMAIL_PROVIDER=sendgrid)
SENDGRID_API_KEY=SG.xxxxxxxx

# ----------------------------------------------------------
# Lead Routing — comma-separated email lists
# ----------------------------------------------------------
# General leads: contact forms, property inquiries, applications
GENERAL_LEAD_RECIPIENTS=manager@yellowstone-am.com,aly@yellowstone-am.com,dor@yellowstone-am.com,lise@yellowstone-am.com,zoe@yellowstone-am.com

# Tour bookings only
TOUR_BOOKING_RECIPIENTS=dor@yellostone-am.com,lise@yellostone-am.com,zoe@yellostone-am.com,manager@yellowstone-am.com

# ----------------------------------------------------------
# Booking / Calendar Integration
# ----------------------------------------------------------
# Provider: custom (built-in form), calendly, google
BOOKING_PROVIDER=custom

# Calendly URL (if BOOKING_PROVIDER=calendly)
# Get this from your Calendly account: https://calendly.com/your-link
CALENDLY_URL=https://calendly.com/yellowstone-am/apartment-tour

# Google Calendar Appointment Schedule URL (if BOOKING_PROVIDER=google)
# Create at: https://calendar.google.com/calendar/u/0/appointments
GOOGLE_CALENDAR_URL=

# ----------------------------------------------------------
# Database
# ----------------------------------------------------------
DB_PATH=./data/leads.db

# ----------------------------------------------------------
# Security / Spam Prevention
# ----------------------------------------------------------
# reCAPTCHA v2/v3 secret key (optional)
RECAPTCHA_SECRET_KEY=

# Honeypot field name — hidden field that bots fill in
HONEYPOT_FIELD=website

# Rate limiting: max submissions per IP per hour
RATE_LIMIT_PER_HOUR=10

# ----------------------------------------------------------
# Future Expansion (prepared but not required now)
# ----------------------------------------------------------
# Telegram bot token for lead notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Twilio for SMS notifications
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
